{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "name": "钴蓝", "slug": "blue", "color": "#3047FF" },
        { "name": "墨黑", "slug": "ink", "color": "#111318" },
        { "name": "辅助灰", "slug": "muted", "color": "#687080" },
        { "name": "冷白", "slug": "paper", "color": "#F5F6F2" },
        { "name": "分隔线", "slug": "line", "color": "#CDD1D8" },
        { "name": "纯白", "slug": "white", "color": "#FFFFFF" }
      ]
    },
    "layout": {
      "contentSize": "820px",
      "wideSize": "1320px"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": ["px", "rem", "em", "%", "vw", "vh"],
      "spacingSizes": [
        { "name": "XS", "slug": "10", "size": "0.5rem" },
        { "name": "S", "slug": "20", "size": "1rem" },
        { "name": "M", "slug": "30", "size": "clamp(1.5rem, 3vw, 2rem)" },
        { "name": "L", "slug": "40", "size": "clamp(2.5rem, 5vw, 4rem)" },
        { "name": "XL", "slug": "50", "size": "clamp(4rem, 8vw, 7rem)" }
      ]
    },
    "typography": {
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "name": "中文系统无衬线",
          "slug": "system-sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif"
        },
        {
          "name": "等宽字体",
          "slug": "system-mono",
          "fontFamily": "ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', monospace"
        }
      ],
      "fontSizes": [
        { "name": "小", "slug": "small", "size": "0.875rem" },
        { "name": "正文", "slug": "medium", "size": "1rem" },
        { "name": "大", "slug": "large", "size": "clamp(1.15rem, 2vw, 1.35rem)" },
        { "name": "标题", "slug": "x-large", "size": "clamp(1.75rem, 4vw, 3rem)" },
        { "name": "展示", "slug": "display", "size": "clamp(3rem, 8vw, 7rem)" }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var:preset|color|paper",
      "text": "var:preset|color|ink"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|20",
      "padding": {
        "left": "clamp(1rem, 4vw, 4rem)",
        "right": "clamp(1rem, 4vw, 4rem)"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system-sans",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "400",
      "lineHeight": "1.7"
    },
    "elements": {
      "button": {
        "border": { "radius": "0", "width": "1px" },
        "color": { "background": "var:preset|color|ink", "text": "var:preset|color|paper" },
        "spacing": { "padding": { "top": "0.75rem", "right": "1.25rem", "bottom": "0.75rem", "left": "1.25rem" } },
        "typography": { "fontSize": "0.95rem", "fontWeight": "650" }
      },
      "heading": {
        "typography": { "fontWeight": "720", "letterSpacing": "-0.035em", "lineHeight": "1.15" }
      },
      "link": {
        "color": { "text": "var:preset|color|ink" }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": { "fontSize": "0.9rem", "fontWeight": "600" }
      },
      "core/site-title": {
        "typography": { "fontSize": "1.15rem", "fontWeight": "750", "letterSpacing": "0.08em" }
      },
      "core/post-content": {
        "spacing": { "blockGap": "1.25rem" }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "页头", "area": "header" },
    { "name": "footer", "title": "页脚", "area": "footer" }
  ]
}
