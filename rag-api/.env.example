# Real local mode. Copy to project-root .env and fill values locally.
APP_ENV=development
RAG_RUNTIME_MODE=real_local
ALLOW_FAKE_MODE=false
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=
