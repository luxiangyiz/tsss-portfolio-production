# ============================================================
# 生产环境变量示例 — 填入实际值后复制为 .env.production
# 警告：此文件不含真实密钥，不要将真实密钥提交到仓库！
# ============================================================

# --- 站点配置 ---
WORDPRESS_SITE_URL=https://example.com

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root-password-32chars
MYSQL_DB_NAME=wordpress
MYSQL_DB_USER=wordpress
MYSQL_DB_PASSWORD=change-me-wp-password-32chars

# --- WordPress ---
WORDPRESS_DB_HOST=mysql
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me-wp-password-32chars
WORDPRESS_TABLE_PREFIX=wp_

# --- RAG API ---
RAG_RUNTIME_MODE=real_remote
CORS_ORIGINS=https://example.com

# 向量嵌入
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=replace-with-secret-at-deploy-time

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=replace-with-secret-at-deploy-time

# 限制
RAG_REQUEST_TIMEOUT=45
RAG_MAX_INPUT_LENGTH=500

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
