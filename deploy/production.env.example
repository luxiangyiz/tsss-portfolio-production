# ============================================================
# 生产环境变量示例 — 填入实际值后复制为 .env.production
# 警告：此文件不含真实密钥，不要将真实密钥提交到仓库！
# ============================================================

# --- 站点配置 ---
# 首次 HTTP 引导部署先使用 http://example.com，证书签发后改为 https。
DOMAIN=example.com
WORDPRESS_SITE_URL=http://example.com
WORDPRESS_FORCE_SSL_ADMIN=false
LETSENCRYPT_EMAIL=admin@example.com
ENABLE_HTTPS=false
APP_VERSION=latest

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root-password-32chars
MYSQL_DB_NAME=wordpress
MYSQL_DB_USER=wordpress
MYSQL_DB_PASSWORD=change-me-wp-password-32chars

# --- WordPress ---
WORDPRESS_DB_HOST=mysql
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me-wp-password-32chars
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_ADMIN_USER=site-admin
WORDPRESS_ADMIN_PASSWORD=change-me-admin-password-32chars
WORDPRESS_ADMIN_EMAIL=admin@example.com

# --- RAG API ---
RAG_RUNTIME_MODE=real_remote
CORS_ORIGINS=http://example.com

# 向量嵌入
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=replace-with-secret-at-deploy-time

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=replace-with-secret-at-deploy-time

# 限制
RAG_REQUEST_TIMEOUT=45
RAG_MAX_INPUT_LENGTH=500
RAG_MAX_CONCURRENT=2
PUBLIC_EXPECTED_DOCUMENTS=9

# --- Qdrant Local ---
# 生产环境不运行独立 Qdrant 容器。
QDRANT_PATH=/app/data/rag/qdrant
